<!DOCTYPE html>
<html lang="en">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />
        <title>User List</title>
        <link
            rel="stylesheet"
            href="https://cdn.jsdelivr.net/npm/bootstrap@4.6.2/dist/css/bootstrap.min.css"
        />
    </head>
    <body>
        <div class="container py-5">
            <div class="d-flex justify-content-between align-items-center mb-4">
                <div>
                    <h1 class="h3 mb-1">Users</h1>
                    <p class="text-muted mb-0">Current records from the database.</p>
                </div>
                <div>
                    <a href="/crud" class="btn btn-primary mr-2">Create user</a>
                    <a href="/" class="btn btn-outline-secondary">Home</a>
                </div>
            </div>

            <div class="card shadow-sm">
                <div class="card-body p-0">
                    <div class="table-responsive">
                        <table class="table table-striped mb-0">
                            <thead class="thead-dark">
                                <tr>
                                    <th>Email</th>
                                    <th>First Name</th>
                                    <th>Last Name</th>
                                    <th>Address</th>
                                    <th>Action</th>
                                </tr>
                            </thead>
                            <tbody>
                                <% if (datalist && datalist.length) { %>
                                    <% for(let i = 0; i < datalist.length; i++) { %>
                                        <tr>
                                            <td><%= datalist[i].email %></td>
                                            <td><%= datalist[i].firstName %></td>
                                            <td><%= datalist[i].lastName %></td>
                                            <td><%= datalist[i].address %></td>
                                            <td>
                                                <a href="/edit-crud?id=<%= datalist[i].id %>" class="btn btn-sm btn-outline-primary">Edit</a>
                                                <a href="/delete-crud?id=<%= datalist[i].id %>" class="btn btn-sm btn-outline-danger" onclick="return confirm('Are you sure?')">Delete</a>
                                            </td>
                                        </tr>
                                    <% } %>
                                <% } else { %>
                                    <tr>
                                        <td colspan="5" class="text-center text-muted py-4">No users found.</td>
                                    </tr>
                                <% } %>
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </body>
</html>