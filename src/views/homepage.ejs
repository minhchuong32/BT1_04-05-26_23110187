<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Home</title>
    <link
      rel="stylesheet"
      href="https://cdn.jsdelivr.net/npm/bootstrap@4.6.2/dist/css/bootstrap.min.css"
    />
  </head>
  <body>
    <div class="container py-5">
      <div class="jumbotron bg-light border">
        <h1 class="display-4">Node CRUD Demo</h1>
        <p class="lead">A small Express + Sequelize app for user management.</p>
        <hr class="my-4" />
        <p>This page shows the current users loaded from MySQL.</p>
        <a href="/crud" class="btn btn-primary mr-2">Create user</a>
        <a href="/get-crud" class="btn btn-outline-primary mr-2">View users</a>
        <a href="/about" class="btn btn-outline-secondary">About</a>
      </div>

      <div class="card shadow-sm">
        <div class="card-body">
          <h2 class="h5 mb-3">Database snapshot</h2>
          <pre class="mb-0"><%= data %></pre>
        </div>
      </div>
    </div>
  </body>
</html>
